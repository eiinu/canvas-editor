{
  "name": "@canvas-editor/editor-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsdown --watch src/index.ts",
    "build": "tsdown src/index.ts --dts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@canvas-editor/shared-protocol": "workspace:*"
  },
  "devDependencies": {
    "tsdown": "latest"
  }
}
