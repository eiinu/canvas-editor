{
  "name": "@eiinu/editor-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm --filter @eiinu/editor-web^... build && tsc -p tsconfig.node.json && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@codemirror/lang-xml": "^6.1.0",
    "@eiinu/editor-core": "workspace:*",
    "@eiinu/editor-xml": "workspace:*",
    "@uiw/react-codemirror": "^4.25.8",
    "codemirror": "^6.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "latest",
    "vite": "latest"
  }
}
