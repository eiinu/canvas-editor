{
  "extends": "../../configs/tsconfig/app.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "module": "es2022",
    "moduleResolution": "bundler",
    "paths": {
      "@eiinu/editor-core": ["../../packages/editor-core/src/index.ts"],
      "@eiinu/editor-utils": ["../../packages/editor-utils/src/index.ts"],
      "@eiinu/editor-xml": ["../../packages/editor-xml/src/index.ts"],
      "@eiinu/editor-protocol": ["../../packages/shared-protocol/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "vite.config.ts"]
}
