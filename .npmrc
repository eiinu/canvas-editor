shared-workspace-lockfile=true
strict-peer-dependencies=false
auto-install-peers=true

# pnpm v10 ignores build scripts by default, we need these for tsdown/rolldown/esbuild
only-built-dependencies[]=esbuild
only-built-dependencies[]=@rolldown/binding-darwin-arm64
only-built-dependencies[]=@rolldown/binding-linux-x64-gnu
only-built-dependencies[]=@rolldown/binding-linux-arm64-gnu
only-built-dependencies[]=@rolldown/binding-darwin-x64
only-built-dependencies[]=@rolldown/binding-win32-x64-msvc
